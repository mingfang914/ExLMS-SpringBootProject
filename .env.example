# 🎓 ExLMS Environment Variables Example
# Copy this file to .env and fill in your actual values.

VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
APP_FRONTEND_URL=http://localhost:3000

# ─── BACKEND CONFIG ────────────────────────────────────────────
# 1. Database
# If running via Docker, use lms-mysql:3306. If local, use localhost:3306
DB_URL=jdbc:mysql://localhost:3306/exlms?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true&connectionCollation=utf8mb4_unicode_ci
DB_USERNAME=root
DB_PASSWORD=your_db_password

# 2. Security
# Secret key for JWT signing (Should be a long random string)
JWT_SECRET_KEY=your_secure_jwt_secret_key_here

# 3. MinIO (File Storage)
MINIO_URL=http://localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# 4. Google OAuth (for backend authentication)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# 5. LiveKit & Meeting Service
# Internal URLs for services
LIVEKIT_URL=ws://localhost:7800
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
MEETING_SERVICE_URL=http://localhost:4000

# WebRTC Networking (Must match Docker ports and Host IP)
LIVEKIT_NODE_IP=127.0.0.1
LIVEKIT_RTC_START=7880
LIVEKIT_RTC_END=7890
LIVEKIT_UDP_RANGE=7880-7890

# Frontend URLs for LiveKit
VITE_LIVEKIT_URL=ws://localhost:7800
VITE_MEETING_SERVICE_URL=http://localhost:4000

# 6. Mail (For password reset and notifications)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password
MAIL_FROM=your_email@gmail.com

# 7. Collaboration Service (Hocuspocus)
COLLAB_SERVICE_PORT=1234
VITE_COLLAB_SERVICE_URL=ws://localhost:1234
CORE_BACKEND_INTERNAL_URL=http://lms-backend:8081/api/v1
REDIS_HOST=lms-redis
REDIS_PORT=6379
